# Copy this file to .env before running docker compose.
# docker compose automatically reads .env from this directory.
# 运行 docker compose 前复制为 .env。docker compose 会自动读取当前目录下的 .env。

# Node.js runtime mode.
# Node.js 运行模式。
NODE_ENV=production

# HTTP bind address. Keep 0.0.0.0 in Docker.
# HTTP 服务监听地址。Docker 中保持 0.0.0.0。
LXFETCH_HOST=0.0.0.0

# HTTP port. Compose maps the same host and container port.
# HTTP 服务端口。Compose 会用同一个值映射宿主机和容器端口。
LXFETCH_PORT=9528

# Optional admin password. Empty disables password checks.
# 可选管理员密码。为空时不校验密码。
LXFETCH_ADMIN_PASSWORD=

# Custom source unsafe VM compatibility mode. Keep disabled unless an old source requires it.
# 自定义音源不安全 VM 兼容模式。只有旧音源确实需要时才开启。
LXFETCH_ALLOW_UNSAFE_VM=false

# Optional full NetEase Cloud Music cookie. Used before custom sources for wy downloads.
# 可选网易云音乐完整 Cookie。wy 平台下载会优先使用它解析。
NETEASE_COOKIE=

# Alternate NetEase cookie variable.
# 网易云 Cookie 备用变量名。
NETEASE_COOKIES=

# Alternate NetEase cookie variable.
# 网易云 Cookie 备用变量名。
WY_COOKIE=

# Optional NetEase cookie file path.
# 可选网易云 Cookie 文件路径。
NETEASE_COOKIE_FILE=

# Alternate NetEase cookie file path variable.
# 网易云 Cookie 文件路径备用变量名。
WY_COOKIE_FILE=

# Download output directory.
# 下载文件保存目录。
LXFETCH_DOWNLOAD_DIR=./data/downloads

# Maximum active download tasks.
# 最大同时下载任务数。
LXFETCH_MAX_CONCURRENT=1

# Per-task bandwidth limit in bytes per second. 0 means unlimited.
# 单任务下载限速，单位 bytes/s。0 表示不限速。
LXFETCH_THROTTLE_BYTES_PER_SECOND=0

# Retry count for interrupted, timed-out, temporary, or incomplete download failures.
# 下载中断、超时、临时错误或不完整文件的重试次数。
LXFETCH_MAX_RETRIES=2

# Retry delay in milliseconds.
# 重试等待时间，单位毫秒。
LXFETCH_RETRY_DELAY_MS=2000

# Download filename pattern. Supports {name}, {singer}, {album}, {source}, {quality}, and {id}.
# 下载文件名模板，支持 {name}、{singer}、{album}、{source}、{quality}、{id}。
LXFETCH_FILENAME_PATTERN="{name} - {singer}"

# Embed cover art into audio files.
# 将封面写入音频文件。
LXFETCH_EMBED_COVER=true

# Embed lyrics into audio files.
# 将歌词写入音频文件。
LXFETCH_EMBED_LYRIC=true

# Write title, artist, album, cover, and lyric tags.
# 写入标题、歌手、专辑、封面、歌词等标签。
LXFETCH_WRITE_TAGS=true

# Verify files and metadata after tagging.
# 标签写入后检查文件和元数据。
LXFETCH_VERIFY_METADATA=true

# Cache fetched covers and lyrics.
# 缓存获取到的封面和歌词。
LXFETCH_CACHE_METADATA=true

# Maximum metadata cache age in days.
# 元数据缓存最大保留天数。
LXFETCH_METADATA_CACHE_MAX_AGE_DAYS=90

# Maximum metadata cache size in bytes.
# 元数据缓存最大体积，单位 bytes。
LXFETCH_METADATA_CACHE_MAX_BYTES=209715200

# Skip creating a new task when the same song already exists locally.
# 本地已有同一首歌时跳过创建新任务。
LXFETCH_SKIP_EXISTING=true

# Allow downloading a better-quality copy when the existing file is lower quality.
# 本地文件音质较低时，允许下载更高音质版本。
LXFETCH_UPGRADE_EXISTING=true

# Maximum new tasks per subscription update. 0 queues all discovered songs.
# 每次订阅更新最多创建的新任务数。0 表示全部入队。
LXFETCH_SUBSCRIPTION_MAX_TASKS_PER_RUN=0

# Delay between creating subscription download tasks in milliseconds.
# 订阅批量创建任务的间隔，单位毫秒。
LXFETCH_SUBSCRIPTION_TASK_CREATE_DELAY_MS=1500
